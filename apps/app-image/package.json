{
  "name": "app-image",
  "version": "0.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5174 && electron .\"",
    "electron:build": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@pal/ipc-types": "workspace:*",
    "@pal/tool-animated": "workspace:*",
    "@pal/tool-gif-maker": "workspace:*",
    "@pal/tool-image": "workspace:*",
    "@pal/ui": "workspace:*",
    "@pal/utils": "workspace:*",
    "cwebp-bin": "^8.0.0",
    "dwebp-bin": "^2.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "gif2webp-bin": "^5.0.0",
    "gifsicle": "^7.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "webpmux-bin": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
